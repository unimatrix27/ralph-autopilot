# ralph-autopilot operator secrets — copy to `.env` (gitignored) and fill in.
# `.env` is sourced + exported by ops/ralph-start.sh on launch, so the supervisor and
# every daemon relaunch (incl. self-update) inherit these. A Claude/Codex-only box needs
# nothing here.

# z.ai / GLM API key for the `zai` provider (ADR-0034). The NAME of this var is what
# `providers.zai.authTokenEnv` references in .ralph/config.yaml; the key itself is read
# at runtime and never stored in config. z.ai keys are of the form <id>.<secret>.
ZAI_API_KEY=
